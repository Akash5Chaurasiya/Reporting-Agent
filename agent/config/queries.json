                    "queue_name": 1,
                    "call_flow_name": 1,
                    "queue_wait_duration": 1,
                    "final_status": 1,
                    "customer_number": 1,
                    "agent_number": 1,
                    "agent_name": 1,
                    "duration": 1,
                    "recording_path": 1,
                    "disposition_form_name": 1,
                    "disconnected_by": 1,
